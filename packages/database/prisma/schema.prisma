generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FailureType {
  HARDWARE
  SOFTWARE // Помилки цілісності даних (XOR)
  NETWORK // Проблеми зі зв'язком (RSSI/Latency)
  AERODYNAMIC // Звалювання (Stall)
  FLIGHT_DYNAMICS // Жорсткі посадки (Hard Landing)
  OTHER
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

enum CAM_STATUS {
  ACTIVE
  DEGRADED
}
model FailureLog {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp   DateTime    @default(now())
  type        FailureType
  severity    Severity
  description String?
  isResolved  Boolean     @default(false)

  uavData   UAVdata @relation(fields: [uavDataId], references: [id])
  uavDataId String  @db.Uuid
}
model UAVdata {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp DateTime @default(now())

  latitude  Float
  longitude Float
  altitude  Float
  fix_type  Int // 0-6; <3 = unreliable GPS

  airspeed    Float // Для детекції Stall
  groundspeed Float // m/s  — basis for analytical redundancy (to compare with Airspeed)
  heading     Float // 0-359 degrees
  pitch       Float
  roll        Float
  throttle    Float // 0-100% (для порівняння з RPM/Vertical Speed)

  batt_rem    Float
  servo_current  Float // To detect servo stalls/blockage
  vibration   Float[] // m/s²  [X, Y, Z]
  rssi        Float //  0-254 Рівень сигналу (dBm)

  cam_status CAM_STATUS // "ACTIVE", "DEGRADED" — для діагностики проблем з камерою
  signal_quality Float // percent video-link quality
  loiter_radius  Float // m, для діагностики проблем з керуванням (може вказувати на проблеми з GPS або керуванням)

  temperature Float // Для детекції Overheat
  logs FailureLog[]

  @@index([timestamp])
}
